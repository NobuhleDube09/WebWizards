PORT=5000
FRONTEND_URL=http://localhost:5000

# Supabase — get from Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Storage bucket names (create in Supabase Dashboard > Storage)
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_LISTING_BUCKET=listings

# Resend — email is handled via Supabase Auth + Resend integration
# Set your Resend API key inside Supabase Dashboard > Auth > SMTP Settings
# No server-side email config needed here

# Claude AI
CLAUDE_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6
